{
  "identifier": "default",
  "description": "Default permissions for the app",
  "local": true,
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "dialog:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "node",
          "cmd": "node",
          "args": true
        }
      ]
    },
    "shell:allow-open"
  ]
}